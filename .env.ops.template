# Coaster Credits Operations Env Template
# Copy this file to `.env.ops.local` and fill values.
# `.env.ops.local` is ignored by git via `*.local`.

# ------------------------------------------------------------
# App / Frontend runtime (Vite)
# ------------------------------------------------------------
VITE_DATA_BACKEND=supabase
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase-anon-key>
VITE_SUPABASE_REDIRECT_URL=https://<your-live-domain>

# ------------------------------------------------------------
# AI keys (frontend currently uses GEMINI_API_KEY)
# Legacy alias API_KEY kept for backward compatibility.
# ------------------------------------------------------------
GEMINI_API_KEY=<gemini-api-key>
API_KEY=<legacy-gemini-api-key-optional>

# ------------------------------------------------------------
# Server/admin scripts (never expose these in frontend)
# Used by migrate/dedupe/import scripts.
# ------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# ------------------------------------------------------------
# Frequent migration parameters
# ------------------------------------------------------------
KARIM_AUTH_UID=<karim-auth-user-uuid>
CADEL_AUTH_UID=<cadel-auth-user-uuid>

# ------------------------------------------------------------
# Cloud Build substitutions (if you run gcloud builds submit)
# ------------------------------------------------------------
_VITE_SUPABASE_URL=https://<project-ref>.supabase.co
_VITE_SUPABASE_ANON_KEY=<supabase-anon-key>
_VITE_SUPABASE_REDIRECT_URL=https://<your-live-domain>
